# Copy this file to .env and fill in at least the admin credentials.

PORT=8787

# Where the SQLite database file is stored. Defaults to ./data/paper_generator.db
# DB_PATH=/absolute/path/to/paper_generator.db

# ── Auth ──────────────────────────────────────────────────────────────
# Secret used to sign login tokens. REQUIRED in production — if you skip
# this, a random secret is generated for you on each machine (fine for
# local dev) but every deploy/restart on a real host will log everyone
# out. Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# The one super-admin account, identified by mobile number (include the
# country code, e.g. +919876543210). Created automatically on first boot
# if both are set (and promoted to admin if the account already exists).
# Leave blank to skip creating an admin account entirely.
ADMIN_PHONE=
ADMIN_PASSWORD=
